  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HistoricalResearchPurpose">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing personal data for historical research purposes.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 5(1)(b) (chunk GDPR_Art5_Para1_b)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketSurveillanceSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A system for monitoring the safety of devices after they have been placed on the market.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GovernanceProcedures"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZE (chunk UKMDR_44ZD_Para5)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N27cba5b3b66a4b479149da8b8b03322a">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#HumanInvolvementForOversight"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasOrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemDocumentationRetention">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 18(1)(b) (chunk EUAI_Art18_Para1_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Retention of documentation for high-risk AI systems</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#UntargetedScraping">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(e) (chunk EUAI_Art5_Para1_e)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The process of collecting data, such as facial images, without a specific target or purpose.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#WorkplaceEmotionInference">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inference of emotions in the workplace.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(f) (chunk EUAI_Art5_Para1_f)</rdfs:comment>
