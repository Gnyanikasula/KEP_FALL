    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The critical evaluation of relevant scientific literature to assess the safety and performance of a medical device.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(3) — Clinical evaluation(a) (chunk EUMDR_Art61_Para3_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketSurveillanceDocumentation">
