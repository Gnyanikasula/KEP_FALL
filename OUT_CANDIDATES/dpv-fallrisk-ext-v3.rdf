    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(3) (chunk GDPR_Art6_Para3_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Objective of public interest that a law or regulation aims to achieve.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EssentialRequirements">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 8(1) (chunk UKMDR_Reg8_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The essential requirements that a medical device must meet as specified in Annex I of the UK MDR 2002.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SafetyComponent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 6(1)(a) (chunk EUAI_Art6_Para1_a)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An AI system intended to be used as a safety component of a product.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketClinicalFollowUp">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZM(3) (chunk EUMDR_Art10_Para9_f)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A follow-up of a device after it has been placed on the market to gather clinical data.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nda474811aecd43c5b40e084fcfc1456c">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
