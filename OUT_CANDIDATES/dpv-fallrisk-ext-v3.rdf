  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataShortcoming">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A shortcoming or limitation in the data used for training, validation, and testing of a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(2)(h) (chunk EUAI_Art10_Para2_h)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TrainingDataSet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(1) (chunk EUAI_AnnexIV_Point2_d)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data sets used for training AI models.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#Data"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RestrictionLifting">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The process of lifting a restriction on processing.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 18(3) (chunk GDPR_Art18_Para3)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProhibitedAIpractice">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(e) (chunk EUAI_Art5_Para1_e)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Prohibition"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An AI practice that is prohibited by law, such as creating or expanding facial recognition databases through untargeted scraping of facial images.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RacialBiometricCategorisation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#BiometricCategorisation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biometric categorisation based on race.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(g) (chunk EUAI_Art5_Para1_g)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#BiasExamination">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(2)(f) (chunk EUAI_Art10_Para2_f)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Examination of data sets for possible biases that are likely to affect health and safety, fundamental rights, or lead to discrimination.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataGovernance"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataGap">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A gap or shortcoming in the data used for training, validation, and testing of a high-risk AI system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(2)(h) (chunk EUAI_Art10_Para2_h)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProductRelatedToUnionHarmonisationLegislation">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 11(2) (chunk EUAI_Art11_Para2)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Product covered by Union harmonisation legislation.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AdverseLegalEffect">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decision that produces an adverse legal effect on a person based solely on the output of high-risk AI systems.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(10) (chunk EUAI_Art26_Para10)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketSurveillanceDocument">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZN(7) (chunk UKMDR_44ZN_Para7)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A document provided by the manufacturer to the Secretary of State as part of post-market surveillance.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LawfulAndFairProcessing">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Measures to ensure lawful and fair processing.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(2) (chunk GDPR_Art6_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ProcessingCondition"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ThresholdAmendment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 51(3) (chunk EUAI_Art51_Para3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An amendment to the thresholds listed in paragraphs 1 and 2 of Article 51.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CustomMadeDevice">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A relevant device that is manufactured specifically in accordance with a written prescription of a registered medical practitioner, or other person authorised to write such a prescription by virtue of his professional qualification, which gives, under his responsibility, specific characteristics as to its design; and intended for the sole use of a particular patient.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 5(1) (chunk UKMDR_Reg5_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#InvestigationalDevice">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(6) (chunk EUMDR_Art10_Para6)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A device that is being investigated in a clinical investigation.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#Device"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ErroneousResults">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZN(3) (chunk UKMDR_44ZN_Para3)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incorrect or inaccurate results produced by a device.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketMonitoring">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Facilitating the post-market monitoring referred to in Article 72.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 12(2) — Record-keeping(b) (chunk EUAI_Art12_Para2_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PatientPrescription">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A prescription written by a healthcare professional for a patient.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 9(5A) (chunk UKMDR_Reg9_Para5)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasLegalBasis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdfs:comment>Legal basis under which personal data is processed.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#System">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A combination of devices which are interfaced or interconnected, or both.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 6 (chunk UKMDR_Reg5_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PriorNotificationForFurtherProcessing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 14(4) (chunk GDPR_Art14_Para4)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The requirement for the controller to provide prior notification to the data subject before further processing of their personal data for a different purpose.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notification"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ExplicitConsentForAutomatedDecisionMaking">
    <rdfs:subClassOf rdf:nodeID="Nbbb202b753774b2ab19a2f63bef28822"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Explicit consent given by the data subject for automated decision-making.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: DUAA 2025 — DUAA 2025, Section 80, Article 22B(2) (chunk DUAA_S80_Art22B_2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RegulatoryComplianceStrategy">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 17(1)(a) (chunk EUAI_Art17_Para1_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A strategy for regulatory compliance, including compliance with conformity assessment procedures and procedures for the management of modifications to the high-risk AI system.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TaskAllocation">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Allocation of tasks based on individual behaviour or personal traits or characteristics.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DecisionMaking"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 4(b) (chunk EUAI_AnnexIII_Point4_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NotifiedBodyDecision">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decisions and documents issued by notified bodies for high-risk AI systems.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 18(1)(d) (chunk EUAI_Art18_Para1_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PMSPeriod">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZC(1) (chunk UKMDR_44ZF_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Duration"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Period beginning with the day on which the first device of a device model is put into service or placed on the market, and ending with the end of the lifetime of the last device of that device model.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FinancialInstitutionGovernance">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal governance, arrangements or processes of financial institutions under Union financial services law.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 19(2) (chunk EUAI_Art19_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GovernanceProcedures"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ThirdPartyInterestProtection">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(7)(d) (chunk GDPR_Art35_Para7_d)</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="N9cb09f5c2e4b4de2acd47ba556b09bab"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Measures to protect the rights and legitimate interests of other persons concerned.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CumulativeComputation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The cumulative amount of computation used for training a general-purpose AI model, measured in floating point operations.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 51(2) (chunk EUAI_Art51_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd737f3af159e4ea180c7668a2ac61dac">
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasPersonalData"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#SpecialCategoryPersonalData"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ApprovedCodeOfConduct">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adherence to an approved code of conduct as referred to in Article 40.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#CodeOfConduct"/>
    <rdfs:subClassOf rdf:nodeID="N6dd1195ac51f44b3abbf1643010f9095"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 32(3) (chunk GDPR_Art32_Para3)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ApprovedBodyDesignation">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(4) (chunk UKMDR_44ZP_Para4)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Designation of tasks that an approved body is authorised to carry out.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceDesignChange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Change in device design or characteristics.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(9) (chunk EUMDR_Art10_Para9_b)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PurposeLink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/pd/owl#Relationship"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(4)(a) — Lawfulness of processing (chunk GDPR_Art6_Para4_a)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A link between the purposes for which personal data have been collected and the purposes of the intended further processing.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N447e2cc6720f4faabe02a22fc50acbad">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemLogs">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 21(2) (chunk EUAI_Art21_Para2)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Automatically generated logs of a high-risk AI system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DentalBrace">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(6) — Clinical evaluation(b) (chunk EUMDR_Art61_Para6_b)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A type of medical device used in dentistry for orthodontic treatment.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SystemDisabling">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Action taken to disable a high-risk AI system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 20(1) (chunk EUAI_Art20_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RiskMitigationEligibility">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 9(3) (chunk EUAI_Art9_Para3)</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="N33c07563dbec492a89f5068fdfe886c7"/>
