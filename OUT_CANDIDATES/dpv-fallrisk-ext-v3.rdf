    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A type of medical device used for closing wounds or joining tissues.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(6) — Clinical evaluation(b) (chunk EUMDR_Art61_Para6_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#IncompatibleProcessing">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing personal data in a manner that is incompatible with the initial purposes.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 5(1)(b) (chunk GDPR_Art5_Para1_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AIforEducation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 3(a) (chunk EUAI_AnnexIII_Point3_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems intended to be used in education and vocational training.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
