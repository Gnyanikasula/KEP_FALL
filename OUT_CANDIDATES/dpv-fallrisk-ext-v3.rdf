    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A simplified form of technical documentation for SMEs.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#TechnicalDocumentation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
