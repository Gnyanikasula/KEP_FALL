  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LegitimateActivity">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 9(2)(d) (chunk GDPR_Art9_Para2_d)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Activities carried out by a not-for-profit body in the course of its legitimate activities.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="N77f6a82cea8644afad1054bb0c049b1c"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RetentionPeriod">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZQ(2) (chunk UKMDR_44ZP_Para3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Duration"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The period for which post-market surveillance documentation must be retained.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemProvider">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Organisation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An entity that provides a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1) (chunk EUAI_Art16_Para1_g)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#UnionMarketDevice">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 87(1)(b) (chunk EUMDR_Art87_Para1_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A device made available on the Union market.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#Device"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasTechnicalOrganisationalMeasure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/owl#TechnicalOrganisationalMeasure"/>
    <rdfs:comment>Technical or organisational measure applied to processing.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PseudonymisationForBiasCorrection">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Pseudonymisation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pseudonymisation as a measure for bias detection and correction in high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(5)(b) (chunk EUAI_Art10_Para5_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NationalCompetentAuthoritiesDocumentationAccess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 18(1)(b) (chunk EUAI_Art18_Para1_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documentation kept at the disposal of national competent authorities</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#VotingBehaviourInfluence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems intended to be used for influencing the voting behaviour of natural persons in the exercise of their vote in elections or referenda.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 8(b) (chunk EUAI_AnnexIII_Point8_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProcessingOperation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(4) (chunk GDPR_Art35_Para4)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
    <rdfs:subClassOf rdf:nodeID="Nc17ea9b0bfcd4e7aa916a3fde7ab0f2b"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A specific type of processing operation subject to data protection impact assessment requirements.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Na730aae742d34831b74fe889c28fb30e">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#DataSecurityManagement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasTechnicalOrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SystemRecall">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Action taken to recall a high-risk AI system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 20(1) (chunk EUAI_Art20_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(15) (chunk EUMDR_Art10_Para15)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#PersonalData"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Information about a device, including its manufacturer and designer.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#UnionOrMemberStateLawRequirement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
