    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CodeOfPractice">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 50(7) (chunk EUAI_Art50_Para7)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A set of guidelines or best practices for implementing obligations regarding the detection and labelling of artificially generated or manipulated content.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Guideline"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LogInterpretationMechanism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3)(f) (chunk EUAI_Art13_Para3_f)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mechanism for interpreting logs in high-risk AI systems.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#HighRiskAILogMechanism"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RightToObjectToProcessing">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 13(2)(b) (chunk GDPR_Art14_Para2_c)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The right to object to processing of personal data</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Right"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ScientificLiteratureEvaluation">
