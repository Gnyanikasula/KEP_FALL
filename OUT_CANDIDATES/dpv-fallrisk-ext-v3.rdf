    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 1(f) (chunk EUAI_AnnexIV_Point1_f)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#WorkersManagement">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 4(a) (chunk EUAI_AnnexIII_Point4_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Management of workers, including monitoring and evaluation.</rdfs:label>
  </rdf:Description>
