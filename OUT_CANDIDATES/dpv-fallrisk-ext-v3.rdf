  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TimelyResponse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A response provided within a specified timeframe (3 working days).</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZI(3)(b) (chunk UKMDR_44ZI_Para3)</rdfs:comment>
  </rdf:Description>
