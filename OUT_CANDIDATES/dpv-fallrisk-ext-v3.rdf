  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#InputDataRelevance">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevance of input data for high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(4) (chunk EUAI_Art26_Para4)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RightToRequestRectification">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 14(2)(c) (chunk GDPR_Art14_Para2_c)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Right"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The right to request rectification of personal data from the controller.</rdfs:label>
