    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GovernanceProcedures"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A quality management system that ensures compliance with the requirements of this Regulation.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(9) (chunk EUMDR_Art10_Para9_h)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceEquivalence">
