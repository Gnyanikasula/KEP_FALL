  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AiOfficeTemplate">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 53(1)(d) (chunk EUAI_Art53_Para1_d)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A template provided by the AI Office for the summary of general-purpose AI model training data.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ManufacturerInspection">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The act of examining and evaluating premises occupied or plant and equipment used by a manufacturer where a body is undertaking tasks in relation to that manufacturer.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(7)(b) (chunk UKMDR_44ZP_Para7)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb9cef418a7ea43f6bcec688d07ad0b3b">
