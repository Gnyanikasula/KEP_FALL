    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing of special categories of personal data for bias detection and correction in high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(5) (chunk EUAI_Art10_Para5_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AnnexIII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elements set out in Annex III of the EU MDR 2017/745 Regulation.</rdfs:label>
