    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3)(d) (chunk EUAI_Art13_Para3_d)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Measures put in place to ensure human oversight of high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SeriousDeterioration">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An unanticipated serious deterioration in a person's state of health.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZH(5) (chunk UKMDR_44ZH_Para5)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RoadTrafficManagement">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Management and operation of road traffic.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 2 (chunk EUAI_AnnexIII_Point2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#CriticalInfrastructure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#GeneralPurposeAIModelWithSystemicRisk">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 52(3) (chunk EUAI_Art52_Para3)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A general-purpose AI model that presents systemic risks due to its specific characteristics.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#VictimRiskAssessment">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assessing the risk of a natural person becoming the victim of criminal offences.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 6(a) (chunk EUAI_AnnexIII_Point6_a)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProductSpecificCS">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(6) — Clinical evaluation(a) (chunk EUMDR_Art61_Para6_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Product-specific Clinical Evaluation Standard (CS) for the clinical evaluation of a device.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ImplantableDevice">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZM(12)(b) (chunk UKMDR_44ZM_Para12)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#DeviceType"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A device considered to be an implantable device under Directive 93/42.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CriminalConvictionsAndOffencesProcessing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing of personal data related to criminal convictions and offences pursuant to Article 10.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(4)(c) (chunk GDPR_Art6_Para4_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#InputDataRepresentativeness">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(4) (chunk EUAI_Art26_Para4)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Representativeness of input data for high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#MarketSurveillanceAuthority">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An authority responsible for monitoring the market and enforcing regulations for high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Authority"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 20(2) (chunk EUAI_Art20_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemOverride">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The act of overriding or reversing the output of a high-risk AI system by a natural person assigned to human oversight.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 14(4)(d) (chunk EUAI_Art14_Para4_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ThirdCountryTransfer">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The transfer of personal data to a third country or international organisation.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Transfer"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 13(1)(f) (chunk GDPR_Art13_Para1_f)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#WearableSensor">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: KEP Variant 5 — Fall-Risk Prediction from Wearables</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#Device"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wearable IMU (accelerometer/gyroscope) device worn by a patient to capture movement data for fall-risk assessment.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NoiseLevel">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#VaryingEnvironment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex I §17.3 (chunk EUMDR_AnnexI_S17_3)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The level of noise in an environment.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#UnjustifiedTreatment">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#DetrimentalTreatment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(ii) (chunk EUAI_Art5_Para1_ii)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unjustified treatment of certain natural persons or groups of persons.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N23c0f717620945288b1b12b4cdc51eb5">
