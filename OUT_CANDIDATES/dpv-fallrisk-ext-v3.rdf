    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex III (chunk EUMDR_Art10_Para4)</rdfs:comment>
  </rdf:Description>
