    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tasks carried out by an approved body for post-market surveillance.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(4) (chunk UKMDR_44ZP_Para4)</rdfs:comment>
