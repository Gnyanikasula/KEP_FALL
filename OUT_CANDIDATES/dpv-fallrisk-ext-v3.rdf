    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(13) (chunk EUMDR_Art10_Para13)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A system for recording incidents.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#MedicalDeviceHazard">
