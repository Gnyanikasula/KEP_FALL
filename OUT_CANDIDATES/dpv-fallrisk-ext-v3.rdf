    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex I §17.2 (chunk EUMDR_AnnexI_S17_2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
