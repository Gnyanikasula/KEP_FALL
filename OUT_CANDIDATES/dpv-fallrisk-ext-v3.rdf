    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assessment of the involvement of a person in a criminal activity.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TrendInformation">
