    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The demonstration that a device subject to clinical evaluation is equivalent to another device to which data relate.</rdfs:label>
