<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasRight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#DataSubject"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/owl#Right"/>
    <rdfs:comment>Right available to the data subject.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <rdfs:comment>Risk associated with the processing activity.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SubliminalTechnique">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(a) (chunk EUAI_Art5_Para1_a)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A technique that operates beyond a person's consciousness.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RequestForPostMarketSurveillanceInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A request made by the Secretary of State to the manufacturer for updates and documents relevant to post-market surveillance.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZN(7) (chunk UKMDR_44ZN_Para7)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PatternDetection">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Detecting decision-making patterns or deviations from prior decision-making patterns.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 6(3)(c) (chunk EUAI_Art6_Para3_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RiskManagementMeasure">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 9(2)(d) (chunk EUAI_Art9_Para2_d)</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="N2c94c8cced974d2c86d6a26f0354c366"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A measure designed to address risks identified in a high-risk AI system.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClassIIIsoftware">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex VIII Rule 11 (chunk EUMDR_AnnexVIII_Rule11)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Software classified as class III according to EU MDR 2017/745.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N6ee675d797c644babb1d1894707c1e48">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasTechnicalOrganisationalMeasure"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#DataSecurityManagement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemAccessibility">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(l) (chunk EUAI_Art16_Para1_l)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The accessibility of a high-risk AI system.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DesignationWithdrawal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Withdrawal of designation of a body under UK MDR 2002, Regulation 44ZP(5)</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(5) (chunk UKMDR_44ZP_Para5)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NoDataProtectionImpactAssessmentRequired">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
    <rdfs:subClassOf rdf:nodeID="N128880ba040d44588e68da2bb8584d74"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(5) (chunk GDPR_Art35_Para5)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing operations for which no data protection impact assessment is required.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemAutonomyLevel">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 14(3) (chunk EUAI_Art14_Para3_b)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The level of autonomy of a high-risk AI system.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HumanOversightDecision">
    <rdfs:subClassOf rdf:nodeID="N8eaff57a2cba42be9348379d0791636e"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DecisionMaking"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decision made by a natural person assigned to human oversight, not to use or to override the output of a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 14(4)(d) (chunk EUAI_Art14_Para4_d)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N44acf35ae3be4668b0c18aafdf88cd92">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketSurveillanceUpdateReport">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A periodic report submitted by the manufacturer to the approved body, detailing the results of post-market surveillance activities.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZM(9) (chunk UKMDR_44ZM_Para9)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProhibitedBehaviourDetection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Detecting prohibited behaviour of students during tests.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#StudentMonitoring"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 3(d) (chunk EUAI_AnnexIII_Point3_d)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NotifiedBodyApprovedChange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Change approved by a notified body for a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 18(1)(c) (chunk EUAI_Art18_Para1_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ResourceManagement">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Management of resources, including security-of-supply related measures.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 17(1) — Quality management system (l) (chunk EUAI_Art17_Para1_l)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#QualityManagementSystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ReligiousOrPhilosophicalBeliefs">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Information about an individual's religious or philosophical beliefs.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SpecialCategoryPersonalData"/>
    <rdfs:subClassOf rdf:nodeID="N1fd96423268144659410bfa7fec04596"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 9(1) (chunk GDPR_Art9_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConformityDeclaration">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Declaration of conformity with the requirements of the regulation.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(9) (chunk EUMDR_Art10_Para9_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RacialOrEthnicOrigin">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 9(1) (chunk GDPR_Art9_Para1)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Information about an individual's racial or ethnic origin.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SpecialCategoryPersonalData"/>
    <rdfs:subClassOf rdf:nodeID="Nfd27f7088e554459abc62f667ffef21f"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#MedicalEmotionInference">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inference of emotions for medical reasons.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(f) (chunk EUAI_Art5_Para1_f)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ModificationManagementProcedure">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A procedure for managing modifications to the high-risk AI system.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 17(1)(a) (chunk EUAI_Art17_Para1_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ComplianceDemonstration">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mechanisms to demonstrate compliance with GDPR.</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="Ndf84e49892f34b33b3268eb3e106216c"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(7)(d) (chunk GDPR_Art35_Para7_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#isMitigatedByMeasure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/owl#TechnicalOrganisationalMeasure"/>
    <rdfs:comment>Indicates a risk is mitigated by a technical or organisational measure.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N128880ba040d44588e68da2bb8584d74">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RightOfAccess">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Right"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The right to obtain confirmation from the controller as to whether or not personal data concerning the data subject are being processed.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 15(1) (chunk GDPR_Art15_Para1_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NationalAccreditationBody">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 29(2) (chunk EUAI_Art29_Para2)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A body responsible for issuing accreditation certificates.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GovernmentalOrganisation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#InformedDecisionImpairment">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The appreciable impairment of a person's ability to make an informed decision.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(a) (chunk EUAI_Art5_Para1_a)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProfilingBasedRiskAssessment">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk assessment based solely on the profiling of a natural person or on assessing their personality traits and characteristics.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(d) (chunk EUAI_Art5_Para1_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LawfulAIExceptions">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 50(1) (chunk EUAI_Art50_Para1)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exceptions to transparency obligations for AI systems authorized by law for specific purposes like detecting, preventing, investigating, or prosecuting criminal offences.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystem">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A high-risk AI system as defined by the EU AI Act.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Technology"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 11(1) (chunk EUAI_Art14_Para4_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AnnexII">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#DeviceTechnicalDocumentation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elements set out in Annex II of the EU MDR 2017/745 Regulation.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex II (chunk EUMDR_Art10_Para4)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ManufacturerPostMarketObligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Obligations of the manufacturer related to post-market surveillance of medical devices.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 83(3) — Post-market surveillance system of the manufacturer(g) (chunk EUMDR_Art83_Para3_g)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PredeterminedSystemChanges">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3) — Transparency and provision of information to deployers(c) (chunk EUAI_Art13_Para3_c)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pre-determined changes to a high-risk AI system and its performance.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SoftwarePackage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 1(d) (chunk EUAI_AnnexIV_Point1_d)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A software package embedded into hardware.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LargeScaleCriminalConvictionsDataProcessing">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing on a large scale of personal data relating to criminal convictions and offences referred to in Article 10.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="Nfee4e1efcdf14c1599f97876d617aad5"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(3)(b) (chunk GDPR_Art35_Para3_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#GeneralMedicalDevice">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A medical device that is not specifically defined or classified under a particular category.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 7(1) (chunk UKMDR_Reg7_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#UtilitySupply">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Supply of water, gas, heating, or electricity.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#CriticalInfrastructure"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 2 (chunk EUAI_AnnexIII_Point2)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataTransferNotificationRight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Right"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 15(2) (chunk GDPR_Art15_Para2)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The right to be informed about the transfer of personal data to a third country or international organisation.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EUdatabaseRegistrationObligation">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Obligation to register high-risk AI systems in the EU database referred to in Article 71.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(8) (chunk EUAI_Art26_Para8)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TransparencyObligation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Obligation to inform natural persons about the use of high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(11) (chunk EUAI_Art26_Para11)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Obligation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProcessingRiskReassessment">
    <rdfs:subClassOf rdf:nodeID="N88c6277bf9b4437abb29d51b5aa14121"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(11) (chunk GDPR_Art35_Para11)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reassessment of processing operations due to a change in risk.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EssentialPrivateServices">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Essential private services that are crucial for an individual's daily life.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Service"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 5(b) (chunk EUAI_AnnexIII_Point5_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EmergencyFirstResponseService">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 5(d) (chunk EUAI_AnnexIII_Point5_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Service"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Emergency first response services, including by police, firefighters and medical aid.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemLogRetention">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keeping logs automatically generated by high-risk AI systems under the control of providers.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(e) (chunk EUAI_Art16_Para1_e)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemLoggingCapability">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 12(3)(a) (chunk EUAI_Art12_Para3_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Logging capability for high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SecretaryOfStateNotification">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZO(3) (chunk UKMDR_44ZO_Para3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#IncidentReportingCommunication"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Notification to the Secretary of State about a non-serious incident.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AIResilience">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ability of a high-risk AI system to withstand attempts to alter its use, outputs, or performance by exploiting system vulnerabilities.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 15(5) (chunk EUAI_Art15_Para5)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClassIIb">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#MedicalDeviceClassification"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Class IIb medical device.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 7(1) (chunk UKMDR_Reg7_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConsentDemonstration">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ability of a controller to demonstrate that the data subject has consented to the processing of their personal data.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 7(1) (chunk GDPR_Art7_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Consent"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AuthorisedRepresentative">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Representative"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The authorised representative of the provider of the AI system, where applicable.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3) — (a) (chunk EUAI_Art13_Para3_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AccuracyDegree">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Degrees of accuracy for specific persons or groups of persons.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 3 (chunk EUAI_AnnexIV_Point3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#UnionLawException">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 9(2)(a) (chunk GDPR_Art9_Para2_a)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A provision in Union or Member State law that prohibits the lifting of the prohibition referred to in paragraph 1 by the data subject.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ExpectedUndesirableSideEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A known and anticipated adverse effect of a medical device.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 87(11) (chunk EUMDR_Art87_Para11)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#Repeatability">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ability of a device to produce consistent results under similar conditions.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex I §17.1 (chunk EUMDR_AnnexI_S17_1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketSurveillance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Activities carried out by manufacturers to proactively collect and review experience gained from devices placed on the market or put into service.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZC(1) (chunk UKMDR_44ZD_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PMCFEvaluationReport">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ClinicalEvaluation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(11) (chunk EUMDR_Art61_Para11)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A report evaluating the results of a post-market clinical follow-up.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClassIDevice">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZL(1)(a) (chunk UKMDR_44ZL_Para1)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A device classified as belonging to class I under a specific directive or regulation.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#DeviceClassification"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc7eaacd4eb384edaa8b93ac450f6292e">
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasOrganisationalMeasure"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#HumanInvolvementForOversight"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AutomaticallyGeneratedLogs">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Logs automatically generated by high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 19(2) (chunk EUAI_Art19_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CEMarking">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(h) (chunk EUAI_Art16_Para1_h)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A marking indicating conformity with EU regulations, affixed to a high-risk AI system or its packaging/documentation.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LogicInvolved">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#MeaningfulInformation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The rationale or reasoning behind the automated decision-making process.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 13(2)(f) (chunk GDPR_Art14_Para2_g)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#InstructionFromController">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 32(4) (chunk GDPR_Art32_Para4)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="N6ee675d797c644babb1d1894707c1e48"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ControllerProcessorAgreement"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An instruction from the controller to a person processing personal data.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TrendInvestigation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZN(6) (chunk UKMDR_44ZN_Para6)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Investigation into identified trends related to a device.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemTransparency">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Obligation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3) — Transparency and provision of information to deployers(iv) (chunk EUAI_Art13_Para3_iv)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The technical capabilities and characteristics of a high-risk AI system to provide information relevant to explain its output.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RobustnessMetric">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metrics used to measure robustness of AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 2(g) (chunk EUAI_AnnexIV_Point2_g)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DesignationRestriction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(5) (chunk UKMDR_44ZP_Para5)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Restriction on designation of a body under UK MDR 2002, Regulation 44ZP(5)</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#OtherRelevantStandard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalStandard"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Other relevant standards and technical specifications applied.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 7 (chunk EUAI_AnnexIV_Point7)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N38c84ca809ab4118aecd5248a0eb7497">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#HumanInvolvementForOversight"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasOrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FurtherProcessingConsequence">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The possible consequences of the intended further processing for data subjects.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(4)(d) (chunk GDPR_Art6_Para4_d)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ReasonedRequest">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(k) (chunk EUAI_Art52_Para5)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A reasoned request from a national competent authority.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#QualityManagementSystem">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(c) (chunk EUAI_Art16_Para1_c)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A quality management system in place for providers of high-risk AI systems.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FeedbackLoop">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 15(4) (chunk EUAI_Art15_Para4)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A loop in which the output of a high-risk AI system influences its future input.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CriminalOffenceVictim">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#DataSubject"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 6(a) (chunk EUAI_AnnexIII_Point6_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A natural person who is at risk of becoming a victim of criminal offences.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketPerformanceEvaluation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 9 (chunk EUAI_AnnexIV_Point9)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The process of evaluating the performance of an AI system in the post-market phase.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PublicAuthorityDeployer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(8) (chunk EUAI_Art26_Para8)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Deployers of high-risk AI systems that are public authorities.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ManufacturerClaim">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The claims made by the manufacturer about a device's performance or safety.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(10) (chunk EUMDR_Art61_Para10)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AnnexIIDevice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A device referred to in the lists in Annex II of Directive 98/79.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZM(12)(d) (chunk UKMDR_44ZM_Para12)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EssentialPrivateService">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Essential private services.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 5(d) (chunk EUAI_AnnexIII_Point5_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Service"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConformityAssessmentProcedure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A procedure for assessing conformity with the EU AI Act Regulation.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 17(1)(a) (chunk UKMDR_44ZM_Para10)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PoliticalCampaignOrganisation">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems used to organise, optimise or structure political campaigns from an administrative or logistical point of view.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 8(b) (chunk EUAI_AnnexIII_Point8_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Naee041dd2c12480f94435232bf16dcff">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#HumanInvolvementForOversight"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasOrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LawEnforcementProfiling">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems used by law enforcement authorities for profiling natural persons in the detection, investigation or prosecution of criminal offences.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 6(e) (chunk EUAI_AnnexIII_Point6_e)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ElectionInfluence">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems intended to be used for influencing the outcome of an election or referendum or the voting behaviour of natural persons in the exercise of their vote in elections or referenda.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 8(b) (chunk EUAI_AnnexIII_Point8_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CCTVFootage">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Video footage captured by Closed-Circuit Television (CCTV) cameras.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(e) (chunk EUAI_Art5_Para1_e)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#Data"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HealthRiskAssessment">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 14(1)(c) (chunk EUAI_AnnexIII_Point7_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The process of evaluating health risks using wearable sensor data.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataRestorability">
    <rdfs:subClassOf rdf:nodeID="Nb98127cf96f84cb5a5b6cf4c0ee3b11f"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalOrganisationalMeasure"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 32(1)(c) (chunk GDPR_Art32_Para1_c)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ability to restore the availability and access to personal data in a timely manner in the event of a physical or technical incident.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConsistencyOfAiSystemPerformance">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 9(6) (chunk EUAI_Art9_Para6)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The property of an AI system performing consistently for its intended purpose.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ExceptionToPostMarketSurveillance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZE(5) (chunk UKMDR_44ZE_Para5)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An exception to the application of post-market surveillance.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ApplicableCriteria">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(5) (chunk UKMDR_44ZP_Para5)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Criteria for designation set out in Annex 8 of Directive 90/385, Annex XI of Directive 93/42, both read with Regulation (EU) No 722/2012 or Annex IX of Directive 98/79</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CorrectiveActions">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZE(3)(a) (chunk UKMDR_44ZN_Para6)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Actions taken to correct safety issues or adverse events with a device, including field safety corrective actions.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SignificantImpactAssessment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An assessment of the impact of an automated decision on a data subject.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: DUAA 2025 — DUAA 2025, Section 80, Article 22B(3) — Restrictions on automated decision-making(a) (chunk DUAA_S80_Art22B_3_a)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ImpactAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#BiasDetectionCorrection">
