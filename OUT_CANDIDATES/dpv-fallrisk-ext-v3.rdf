    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(3) (chunk EUMDR_Art61_Para1)</rdfs:comment>
  </rdf:Description>
