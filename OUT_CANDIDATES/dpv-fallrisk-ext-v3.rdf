    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 8(3) (chunk UKMDR_Reg8_Para3)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PerformanceMetricAppropriateness">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The appropriateness of a performance metric for a specific AI system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 4 (chunk EUAI_AnnexIV_Point4)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SeriousIncidentTiming">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 87(5) (chunk EUMDR_Art87_Para5)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#IncidentManagementProcedures"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The timing requirements for reporting serious incidents, including immediate reporting and 10-day deadline.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HumanOversightMeasure">
