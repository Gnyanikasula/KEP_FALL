    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The tools and systems used to enable effective human oversight of high-risk AI systems.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FinancialInstitutionsLogRequirement">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Requirement for financial institutions to maintain logs as part of their internal governance.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(6) (chunk EUAI_Art26_Para6)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GovernanceProcedures"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EstimatedNumberOfUsers">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The estimated number of users of a medical device.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZK(2)(d) (chunk UKMDR_44ZK_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#Device"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#UnanticipatedSeriousDeterioration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An unanticipated serious deterioration in a person's state of health.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 87(5) (chunk EUMDR_Art87_Para5)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#SeriousIncidentReport"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAiSystemPackaging">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The packaging of a high-risk AI system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(b) (chunk EUAI_Art16_Para1_b)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FalsifiedDevice">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Any device with a false presentation of its identity and/or of its source and/or its CE marking certificates or documents relating to CE marking procedures.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 2(9) (chunk EUMDR_Art2_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#Device"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#Suture">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A type of medical device used for closing wounds or joining tissues.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(6) — Clinical evaluation(b) (chunk EUMDR_Art61_Para6_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
