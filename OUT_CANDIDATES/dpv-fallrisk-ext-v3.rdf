    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Authorisation by Member State law.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketSurveillanceUpdate">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The process of updating technical documentation and information based on data gathered through the post-market surveillance system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZE(4) (chunk UKMDR_44ZN_Para7)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EUDeclarationOfConformityRetention">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Retention of EU declaration of conformity for a specified period.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(8) (chunk EUMDR_Art10_Para8)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PeriodicSummaryReport">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#IncidentManagementProcedures"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZH(6) (chunk EUMDR_Art87_Para9)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A report submitted periodically by the manufacturer as an alternative to individual serious incident reports.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N32ce894b900f4d6891a6f2b5665390bb">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#HumanInvolvementForOversight"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasOrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#VitalInterest">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Protecting the vital interests of the data subject or of another natural person.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(1)(d) (chunk GDPR_Art6_Para1_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceForPerformanceEvaluation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 2(1) — Interpretation E+W+S (chunk UKMDR_Reg2_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A product which is intended by its manufacturer to be subject to one or more performance evaluation studies in laboratories for medical analysis or in other appropriate environments outside his own premises.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#VerifiableDocumentation">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documentation that can be verified.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 53(5) (chunk EUAI_Art53_Para5)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RelevantDevice">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shall be construed in accordance with regulation 6.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 5(1) (chunk UKMDR_Reg5_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TestProcedure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A procedure for testing high-risk AI systems before, during, and after development.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 17(1)(d) (chunk EUAI_Art17_Para1_d)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TrendInIncidents">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Analysis of trends in incidents related to a device, including those subject to trend reporting under regulation 44ZN.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZE(3)(b) (chunk UKMDR_44ZE_Para3)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#IncidentManagementProcedures"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAIConformityDocumentation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documentation necessary to demonstrate conformity of high-risk AI systems with regulatory requirements.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 21(1) (chunk EUAI_Art21_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SystemLifetimeLogging">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The recording of events (logs) over the entire lifetime of a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 12(1) (chunk EUAI_Art12_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#BenefitRiskRatio">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The comparison of the benefits and risks of a device to determine its acceptability.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(1) (chunk EUMDR_Art61_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAIConformityDemonstration">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(k) (chunk EUAI_Art16_Para1_k)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Obligation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Demonstration of conformity with requirements for high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasNotice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/owl#Notice"/>
    <rdfs:comment>Notice provided to data subjects (transparency obligations).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#JustificationForException">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The rationale provided for exceptions to demonstrating conformity with general safety and performance requirements based on clinical data.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(10) (chunk EUMDR_Art61_Para10)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Justification"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceAlterationRestriction">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZI(3)(c) (chunk UKMDR_44ZI_Para3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A restriction on altering a device or a sample of a batch during an investigation.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PackagingDocumentation">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/pd/owl#Location"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The packaging or accompanying documentation of a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 16(1)(h) (chunk EUAI_Art16_Para1_h)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemTrainingData">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3) — Transparency and provision of information to deployers(vi) (chunk EUAI_Art13_Para3_vi)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Specifications for the input data used for training, validation, and testing of high-risk AI systems.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#Data"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#VaryingEnvironment">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex I §17.3 (chunk EUMDR_AnnexI_S17_3)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A varying environment, such as a environment with varying levels of light or noise.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N135aecad5d094c159e564019c320b8ec">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CriticalInfrastructure">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 2 (chunk EUAI_AnnexIII_Point2)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infrastructure that is critical to the functioning of society and the economy.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClearAndDistinguishableInformation">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Information provided in a clear and distinguishable manner.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 50(5) (chunk EUAI_Art50_Para5)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#TransparencyObligation"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N6dd1195ac51f44b3abbf1643010f9095">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasTechnicalOrganisationalMeasure"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#DataSecurityManagement"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N5fd3dc794b2e401ba2281693c87b3403">
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ContextualSetting">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(4) (chunk EUAI_Art10_Para4)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Context"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Characteristics or elements particular to a specific contextual setting.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ApprovedBodyInformationRequest">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(8) (chunk UKMDR_44ZP_Para8)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Request for information and documents from an approved body, including budgetary documents.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ControllerIntervention">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A measure that enables a data subject to obtain human intervention from a controller in relation to automated decision-making.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: DUAA 2025 — DUAA 2025, Section 80, Article 22C(2)(c) (chunk DUAA_S80_Art22C_2_c)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ListOfProcessingActivities">
    <rdfs:subClassOf rdf:nodeID="N447e2cc6720f4faabe02a22fc50acbad"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(6) (chunk GDPR_Art35_Para6)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A list of processing activities that require a data protection impact assessment.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PublicInterestArchiving">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Archiving of personal data in the public interest.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ArchivingPurpose"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 5(1)(e) (chunk GDPR_Art5_Para1_e)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LawEnforcementAI">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 6(a) (chunk EUAI_AnnexIII_Point6_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#AISystem"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems intended to be used by or on behalf of law enforcement authorities.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SexLifeOrSexualOrientationBiometricCategorisation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(g) (chunk EUAI_Art5_Para1_g)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biometric categorisation based on sex life or sexual orientation.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#BiometricCategorisation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SpecialCategoryDataProcessingCondition">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(5) (chunk EUAI_Art10_Para5_c)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ProcessingCondition"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Condition for processing special categories of personal data in high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AlternativeTreatmentOption">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ClinicalEvaluation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Available treatment options considered in clinical evaluation.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(3)(c) (chunk EUMDR_Art61_Para3_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#JudicialCapacity">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 9(2)(f) (chunk GDPR_Art9_Para2_f)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="Ne02e9910059145daa6fc030d1baeca09"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acting in judicial capacity.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceDescription">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Description of a device, including any unique device identifiers.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#Device"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZJ(2)(c) (chunk UKMDR_44ZJ_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SoftwareVersion">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 1(c) (chunk EUAI_AnnexIV_Point1_c)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The versions of relevant software or firmware.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#BodyCriteriaAssessment">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The evaluation of whether a body meets the criteria set out in Annex 8 of Directive 90/385, Annex XI of Directive 93/42, both read with Regulation (EU) No 722/2012 or Annex IX of Directive 98/79.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZP(7) (chunk UKMDR_44ZP_Para7)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AdditionalInformationForFurtherProcessing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant information provided for further processing of personal data, as referred to in paragraph 2 of Article 13.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 13(3) (chunk GDPR_Art13_Para3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notification"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FundamentalRightsProtectionLevel">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 6(8) (chunk EUAI_Art6_Para8)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The level of protection of fundamental rights provided by a regulation.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NotifyingAuthority">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The authority responsible for notifying conformity assessment bodies.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Authority"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 29(1) (chunk EUAI_Art29_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PublicCriminalOffenceReporting">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 50(1) (chunk EUAI_Art50_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems made available to the public for reporting criminal offences, impacting transparency obligations.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ListOfProcessingOperations">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:subClassOf rdf:nodeID="N5fd3dc794b2e401ba2281693c87b3403"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(5) (chunk GDPR_Art35_Para5)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">List of processing operations for which no data protection impact assessment is required.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EligibilityEvaluation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 5(a) (chunk EUAI_AnnexIII_Point5_a)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The process of assessing whether an individual is eligible for essential public assistance benefits and services.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N8d143c2e691f4050b21621dbe4a0bd40">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConformityAssessmentBody">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A body that performs conformity assessment activities.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Organisation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 29(1) (chunk EUAI_Art29_Para3)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#InterpretationTool">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 14(4)(c) (chunk EUAI_Art14_Para4_c)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A tool or method used to facilitate the interpretation of a high-risk AI system's output.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ApprovedBodyInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Information and assessments provided by an approved body.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZI(2) (chunk UKMDR_44ZI_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#StatutoryObligationOfSecrecy">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ProfessionalSecrecy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Statutory obligation of secrecy regulated by Union or Member State law.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 14(5)(d) (chunk GDPR_Art14_Para5_d)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ManagementResponsibility">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The responsibility of the management as part of the quality management system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GovernanceProcedures"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(9) (chunk EUMDR_Art10_Para9_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HumanOversightAssignment">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 14(4) (chunk EUAI_Art14_Para4_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#EntityInvolvement"/>
    <rdfs:subClassOf rdf:nodeID="N83d151b2308e46329344917155d94ea4"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assignment of natural persons to perform human oversight of a high-risk AI system.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EmergencyCallEvaluation">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Service"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems intended to evaluate and classify emergency calls by natural persons.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 5(d) (chunk EUAI_AnnexIII_Point5_d)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N77f6a82cea8644afad1054bb0c049b1c">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#SpecialCategoryPersonalData"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasPersonalData"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeployersInterpretability">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ability of deployers to interpret the output of high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(1) (chunk EUAI_Art13_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#Capability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AppropriateSafeguard">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(4)(e) (chunk GDPR_Art6_Para4_e)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A safeguard that ensures the protection of personal data, such as encryption or pseudonymisation.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ned33c8755ddb4a699edd914772d9d942">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DiscriminationRisk">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(2)(f) (chunk EUAI_Art10_Para2_f)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risk of discrimination prohibited under Union law.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#GeographicalSetting">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Context"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(4) (chunk EUAI_Art10_Para4)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Characteristics or elements particular to a specific geographical setting.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SystemPerformanceChange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Changes to the performance of a high-risk AI system.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3) — Transparency and provision of information to deployers(c) (chunk EUAI_Art13_Para3_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CompletenessOfData">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataGovernance"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The extent to which the data is complete in view of the intended purpose.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(3) (chunk EUAI_Art10_Para3)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClinicalEvaluationProcedure">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ClinicalEvaluation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Defined and methodologically sound procedure for clinical evaluation.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(3) (chunk EUMDR_Art61_Para3_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EssentialRequirementsCompliance">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ComplianceAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Compliance with relevant essential requirements.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 9(7) (chunk UKMDR_Reg9_Para7)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CommissionDecisionExOfficio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 51(1)(b) (chunk EUAI_Art51_Para1_b)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A decision made by the Commission ex officio.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HumanOversightVerification">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 14(5) (chunk EUAI_Art14_Para5)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdfs:subClassOf rdf:nodeID="Ndfda459ac687460fafce2bbc5bc77eee"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verification of AI system output by at least two natural persons with necessary competence, training, and authority.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAILog">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 19(1) (chunk EUAI_Art19_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Automatically generated logs by high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataSetAvailabilityAssessment">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(2) — Data and data governance (e) (chunk EUAI_Art10_Para2_e)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assessment of the availability of data sets needed for high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceRecall">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The action of recalling a device from users due to non-conformity or serious risk.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(12) (chunk EUMDR_Art10_Para12)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FinancialFraudDetectionExemption">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exemption for AI systems used for detecting financial fraud.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 5(b) (chunk EUAI_AnnexIII_Point5_b)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DevicePlacement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The act of placing a device on the market.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZE(5) (chunk UKMDR_44ZE_Para5)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N2e7b1513f3dd4f2dae3be67e163516ff">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasTechnicalOrganisationalMeasure"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#DataSecurityManagement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceNonConformity">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZG(1) (chunk UKMDR_44ZG_Para1)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A situation where a device does not meet the relevant essential requirements.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceManufacturing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(1) (chunk EUMDR_Art10_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The manufacturing of a device in accordance with the requirements of the EU MDR 2017/745 Regulation.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighImpactCapability">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 51(1)(a) (chunk EUAI_Art51_Para2)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A capability of a general-purpose AI model that has a significant effect or influence.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PeriodicSafetyUpdateReport">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZF(5) (chunk UKMDR_44ZM_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A periodic safety update report issued as part of post-market surveillance.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#MedicinalProduct">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A product that is liable to act on the human body with action ancillary to that of a medical device.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 9(8) (chunk UKMDR_Reg9_Para8)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SME">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 11(1) (chunk EUAI_Art11_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A small or medium-sized enterprise.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Organisation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DisproportionateEffort">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Justification"/>
