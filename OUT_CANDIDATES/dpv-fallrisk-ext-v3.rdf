    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medical devices that have similar characteristics, properties, or uses.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZM(2)(b) (chunk UKMDR_44ZM_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LegalObligationUnionLaw">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 17(3)(b) (chunk GDPR_Art17_Para3_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalObligation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A legal obligation which requires processing by Union law to which the controller is subject.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasPersonalData">
