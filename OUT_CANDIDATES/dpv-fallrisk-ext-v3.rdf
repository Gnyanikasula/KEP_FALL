  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EasilyAccessibleForm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A form that is easily accessible.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 7(2) (chunk GDPR_Art7_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketSurveillancePeriod">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The period during which post-market surveillance activities are conducted.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Duration"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZL(3) (chunk UKMDR_44ZL_Para3)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SeriousIncidentReport">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#IncidentReportingCommunication"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZH(2) (chunk EUMDR_Art87_Para5)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A report that includes details about a serious incident, including the device description, incident description, and manufacturer's conclusions.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasDataSubject">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/owl#DataSubject"/>
    <rdfs:comment>Data subject whose personal data is processed.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataProtectionOfficerAdvice">
    <rdfs:subClassOf rdf:nodeID="N1a82929b76184f7899eb10ee923f620f"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Consultation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The advice provided by the data protection officer during a data protection impact assessment.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 35(2) (chunk GDPR_Art35_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TechnicallyFeasibleRiskReduction">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The reduction of risks through adequate design and development of the high-risk AI system to the extent that is technically feasible.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RiskMitigationMeasure"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 9(5)(a) (chunk EUAI_Art9_Para5_a)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N61843d8a8f984fff8ac861168da62e3b">
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasPersonalData"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#HealthData"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#Quality_Management_System">
