    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ClinicalEvaluation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A plan for post-market clinical follow-up.</rdfs:label>
