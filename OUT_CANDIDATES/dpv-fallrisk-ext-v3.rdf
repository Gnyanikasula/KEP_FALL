  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AccountabilityFramework">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 17(1)(m) (chunk EUAI_Art17_Para1_m)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A framework setting out the responsibilities of the management and other staff.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataMinimisation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 5(1)(c) (chunk GDPR_Art25_Para2)</rdfs:comment>
