    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 9(2)(f) (chunk GDPR_Art9_Para2_f)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exercise of legal claims.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProcessingForPublicAuthorities">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(1)(f) (chunk GDPR_Art6_Para1_f)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing carried out by public authorities in the performance of their tasks.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Processing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TestingDataGovernance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data governance for testing data sets in high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(2) — Data and data governance(b) (chunk EUAI_Art10_Para2_b)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#HighRiskAISystemDataGovernance"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConsentForSpecificPurpose">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Consent given by the data subject for a specific purpose.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#Consent"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(1)(a) (chunk GDPR_Art6_Para1_a)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#MitigatableRisk">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 9(3) (chunk EUAI_Art9_Para3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risks that can be reasonably mitigated or eliminated through the development or design of the high-risk AI system.</rdfs:label>
  </rdf:Description>
