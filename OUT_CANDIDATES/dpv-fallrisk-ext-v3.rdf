    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 32(4) (chunk GDPR_Art32_Para4)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A requirement to process personal data due to Union or Member State law.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HarmonisedStandardsChange">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(9) (chunk EUMDR_Art10_Para9_m)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Change in harmonised standards or CS by reference to which the conformity of a device is declared.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FallRiskScore">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numerical fall-risk probability score derived from gait and accelerometer data by the SHIELD v2 model.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#InferredPersonalData"/>
    <rdfs:subClassOf rdf:nodeID="Nbda54992a5e64a20ada010a0fc30f739"/>
