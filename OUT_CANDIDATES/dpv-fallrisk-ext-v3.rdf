    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Derived gait parameters (stride length, cadence, asymmetry index) computed from accelerometer and gyroscope sensor data.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#EducationalInstitution">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/pd/owl#Location"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 3(c) (chunk EUAI_AnnexIII_Point3_c)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Educational and vocational training institutions at all levels.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClinicalEvaluationReport">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZM(2)(a) (chunk EUMDR_Art61_Para2)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A report that provides an assessment of the clinical data related to a medical device.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ClinicalEvaluation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#OfferOfInformationSocietyService">
