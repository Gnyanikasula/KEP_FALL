  <rdf:Description rdf:nodeID="Neada73a090704df08237285a0e908670">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LegalClaim">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A claim or lawsuit that requires personal data for its establishment, exercise, or defence.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 18(1)(c) (chunk GDPR_Art18_Para1_c)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FirstInteractionExposure">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 50(5) (chunk EUAI_Art50_Para5)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Time of the first interaction or exposure to the AI system.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClassificationRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 6(2) (chunk EUAI_Art6_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rules for classifying high-risk AI systems.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ContractualObligations">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The obligations that arise from a contract to which the data subject is a party.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ProcessingCondition"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 6(1)(b) (chunk GDPR_Art6_Para1_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AIOutputExplanation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Information provided to explain the output of a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(3) — Transparency and provision of information to deployers(iv) (chunk EUAI_Art13_Para3_iv)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CooperationWithAuthority">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The act of collaborating with competent authorities in relation to high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#EntityInvolvement"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 26(12) (chunk EUAI_Art26_Para12)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RestrictionOfProcessingNotification">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Notification provided to a data subject before the restriction of processing is lifted.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Right"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 18(3) (chunk GDPR_Art18_Para3)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#VerificationPeriod">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Duration"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 18(1)(a) (chunk GDPR_Art18_Para1_a)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A period enabling the controller to verify the accuracy of personal data.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LoggingCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 12(2) — Record-keeping(a) (chunk EUAI_Art12_Para2_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ability to enable the recording of events relevant for identifying situations that may result in the high-risk AI system presenting a risk.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#WrittenPolicies">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 17(1) (chunk EUAI_Art17_Para1_g)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documented policies and procedures for quality management.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClinicalInvestigationProposal">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ClinicalEvaluation"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(2) (chunk EUMDR_Art61_Para2)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Proposal for clinical investigation of a medical device.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AnnexAmendment">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Amendment of an annex to ensure technical documentation aligns with progress.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 11(3) (chunk EUAI_Art11_Para3)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ArtisticCreativeWork">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#PublicInterestOngoing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 50(4) (chunk EUAI_Art50_Para4)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Evidently artistic, creative, satirical, fictional or analogous work or programme.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfee4e1efcdf14c1599f97876d617aad5">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#Regulation7222012">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Requirements set out in Regulation (EU) No 722/2012.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 8(2) (chunk UKMDR_Reg8_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/risk/owl#hasRiskAssessment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdfs:range rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment>Risk assessment associated with the processing activity.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N2989f377307447cc97f285e82cb9b199">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasOrganisationalMeasure"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#HumanInvolvementForOversight"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceLifecycle">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Context"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The entire lifetime of a device, from development to disposal.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 83(2) (chunk EUMDR_Art83_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataGovernanceAssessment">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assessment of data governance and management practices for high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(2) — Data and data governance (e) (chunk EUAI_Art10_Para2_e)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FinancialInstitutionDocumentationKeeping">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 18(3) (chunk EUAI_Art18_Para3)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documentation keeping for financial institutions subject to Union financial services law.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SupplementalSafeguardRequirements">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: DUAA 2025 — DUAA 2025, Section 80, Article 22D(3)(b) (chunk DUAA_S80_Art22D_3_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Additional requirements for safeguards beyond what is specified in Article 22C(2).</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConsentRecord">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 7(1) (chunk GDPR_Art7_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A record of the data subject's consent to the processing of their personal data.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AsylumRiskAssessment">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Assessment of risks related to asylum posed by a natural person.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 7(b) (chunk EUAI_AnnexIII_Point7_b)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceDocumentation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(5) (chunk EUMDR_Art10_Para14)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documentation related to a device, including information about its design, manufacture, and use.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SensitiveProcessing">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The processing of sensitive personal data, which requires additional safeguards.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: DUAA 2025 — DUAA 2025, Section 80, Article 22D(5) (chunk DUAA_S80_Art22D_5)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SpecialCategoryPersonalData"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PostMarketMonitoringPlan">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 9 (chunk EUAI_AnnexIV_Point9)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A plan for monitoring the performance of an AI system in the post-market phase.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AISystemforPolygraph">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An artificial intelligence system designed to be used as a polygraph or similar tool.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 7(a) (chunk EUAI_AnnexIII_Point7_a)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#AISystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#Device">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A device as referred to in the UK MDR 2002.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZD(4) (chunk UKMDR_44ZD_Para4)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DataPoisoning">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A type of attack where an unauthorized third party attempts to manipulate the training data set of a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 15(5) (chunk EUAI_Art15_Para5)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CompetentAuthorityRequest">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reasoned request by a competent authority for access to high-risk AI system logs.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 21(2) (chunk EUAI_Art21_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#NationalCompetentAuthority"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#FacialRecognitionDatabase">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#Data"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(e) (chunk EUAI_Art5_Para1_e)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A database of facial images used for facial recognition purposes.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProbabilisticThreshold">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 9(8) (chunk EUAI_Art9_Para8)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probabilistic thresholds used for testing high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SignificantHarm">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A harm that is significant and caused to a person, another person, or a group of persons.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(a) (chunk EUAI_Art5_Para1_a)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N18334e0977944b3d82ab5a362e3f2280">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#HealthData"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasPersonalData"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceSample">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(14) (chunk EUMDR_Art10_Para14)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#Device"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A sample of a device provided by the manufacturer.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N83d151b2308e46329344917155d94ea4">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#HumanInvolvementForOversight"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/owl#hasOrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#VerificationResultVerifier">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 12(3)(d) (chunk EUAI_Art12_Para3_d)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural person involved in verifying the results of a high-risk AI system.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Entity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LearningOutcomeEvaluation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 3(b) (chunk EUAI_AnnexIII_Point3_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Evaluation of learning outcomes in educational and vocational training institutions.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClinicalInvestigation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 9(7) (chunk EUMDR_Art61_Para3_b)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A device intended for clinical investigation.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#WorkingDayResponseTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZM(13) (chunk UKMDR_44ZM_Para13)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The time frame within which an approved body must respond to a request, measured in working days.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TechnicalDocumentation">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 11(1) (chunk EUAI_Art11_Para1)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Technical documentation of a high-risk AI system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceModificationManagement">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Procedures for management of modifications to devices covered by the quality management system.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GovernanceProcedures"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(9)(a) (chunk EUMDR_Art10_Para9_a)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CriticalDigitalInfrastructure">
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#CriticalInfrastructure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Digital infrastructure that is critical to the functioning of society and the economy.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 2 (chunk EUAI_AnnexIII_Point2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ExcludedMeasures">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Safeguard"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Measures which are not to be taken to satisfy one or more of points (a) to (d) of Article 22C(2).</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: DUAA 2025 — DUAA 2025, Section 80, Article 22D(3) — Further provision about automated decision-making(c) (chunk DUAA_S80_Art22D_3_c)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N33c07563dbec492a89f5068fdfe886c7">
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <owl:onProperty rdf:resource="https://w3id.org/dpv/risk/owl#hasRiskAssessment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RegulatedAutomatedDecisionMaking">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DecisionMaking"/>
    <rdfs:subClassOf rdf:nodeID="N38c84ca809ab4118aecd5248a0eb7497"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Automated decision-making processes that are regulated by specific laws or articles.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: DUAA 2025 — DUAA 2025, Section 80, Article 22D(1) (chunk DUAA_S80_Art22D_1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N91e676e342354b5bb0ec1b7b9be18df6">
