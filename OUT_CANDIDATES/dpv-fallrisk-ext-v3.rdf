    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/dpv/owl#DataSecurityManagement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeployersTraining">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 9(5)(c) (chunk EUAI_Art9_Para5_c)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RiskMitigationMeasure"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Training provided to deployers of high-risk AI systems.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LogRetentionPeriod">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 19(1) (chunk EUAI_Art19_Para1)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Period for which logs are kept, as specified by the intended purpose of the high-risk AI system.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Duration"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ProviderInsolvency">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The event of a provider going bankrupt or ceasing its activity.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#Incident"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 18(2) (chunk EUAI_Art18_Para2)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TargetedInformationCampaign">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 87(10) (chunk EUMDR_Art87_Para10)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A targeted information campaign to encourage and enable reporting of serious incidents.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RepresentativenessOfData">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The extent to which the data is representative of the persons or groups of persons in relation to whom the high-risk AI system is intended to be used.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataGovernance"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(3) (chunk EUAI_Art10_Para3)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RiskToFundamentalRights">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex IV, Point 3 (chunk EUAI_AnnexIV_Point3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Risks to fundamental rights.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SpecialCategoryDataProcessingRestriction">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(5) (chunk EUAI_Art10_Para5_d)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Restriction on processing special categories of personal data.</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ProcessingCondition"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#NotificationApplication">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 29(1) (chunk EUAI_Art29_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notification"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An application submitted by a conformity assessment body for notification.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#HighRiskAISystemDocumentation">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 13(2) (chunk EUAI_Art13_Para2)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documentation accompanying high-risk AI systems.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RiskOfVaryingLikelihoodAndSeverity">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 25(1) (chunk GDPR_Art25_Para1)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#Risk"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The potential risks to the rights and freedoms of natural persons posed by the processing.</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#BiometricCategorisation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Prohibition"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Categorisation of individuals based on their biometric data.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(g) (chunk EUAI_Art5_Para1_g)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ConsentWithdrawalNotice">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notice"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 13(2)(c) (chunk GDPR_Art13_Para2_c)</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Notice provided to the data subject regarding the withdrawal of consent.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ImplementingActs">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legally binding acts adopted by the Commission to implement regulations.</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(13) (chunk EUMDR_Art61_Para13)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AnalogousMedicalDevice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A medical device that is similar to the product being evaluated.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(9) (chunk EUMDR_Art61_Para9)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AccuracyMetric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#RiskAssessment"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A metric used to measure the accuracy of a high-risk AI system.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 15(3) (chunk EUAI_Art15_Para3)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PersonalProtectiveEquipment">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 9(9) (chunk UKMDR_Reg9_Para9)</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Personal protective equipment as defined in Regulation (EU) 2016/425.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LightLevel">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The level of light in an environment.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex I §17.3 (chunk EUMDR_AnnexI_S17_3)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#VaryingEnvironment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#AnnexVIIIConditions">
