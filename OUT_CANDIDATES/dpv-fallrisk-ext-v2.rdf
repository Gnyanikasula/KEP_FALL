    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A system for recording incidents.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 10(13) (chunk EUMDR_Art10_Para13)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LawEnforcementAI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#AISystem"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AI systems intended to be used by or on behalf of law enforcement authorities.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Annex III, Point 6(a) (chunk EUAI_AnnexIII_Point6_a)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/risk/owl#DataUnverified">
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#DataRisk"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#TimelyResponse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A response provided within a specified timeframe (3 working days).</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZI(3)(b) (chunk UKMDR_44ZI_Para3)</rdfs:comment>
  </rdf:Description>
