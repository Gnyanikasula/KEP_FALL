    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An investigation conducted as part of post-market surveillance.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 44ZI(3) (chunk UKMDR_44ZI_Para3)</rdfs:comment>
