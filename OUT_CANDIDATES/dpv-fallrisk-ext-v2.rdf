    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataGovernance"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The extent to which the data is representative of the persons or groups of persons in relation to whom the high-risk AI system is intended to be used.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 10(3) (chunk EUAI_Art10_Para3)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#CEMarking">
