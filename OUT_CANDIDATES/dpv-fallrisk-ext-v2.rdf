    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The loss of personal data in a manner that is not in accordance with the law.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 32(2) (chunk GDPR_Art32_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#ClassIIbSoftware">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Software classified as class IIb according to EU MDR 2017/745.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Annex VIII Rule 11 (chunk EUMDR_AnnexVIII_Rule11)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#PlacingOnTheMarket">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The first making available in return for payment or free of charge of a new or fully refurbished device, other than a device intended for clinical investigation, with a view to distribution, use, or both, on the Great Britain market.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: UK MDR 2002 — UK MDR 2002, Regulation 2(1) — Interpretation E+W+S (chunk UKMDR_Reg2_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#SignificantHarm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A harm that is significant and caused to a person, another person, or a group of persons.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(a) (chunk EUAI_Art5_Para1_a)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataProcessingRecord">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
  </rdf:Description>
