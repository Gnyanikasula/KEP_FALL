    <rdf:type rdf:resource="https://w3id.org/dpv/pd/owl#Family"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/risk/owl#Blackmail">
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#MaliciousActivity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/risk/owl#RiskMatrix7x7">
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskMatrix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#RacialOrEthnicOrigin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SpecialCategoryPersonalData"/>
