    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Right"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The right to be informed about the transfer of personal data to a third country or international organisation.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 15(2) (chunk GDPR_Art15_Para2)</rdfs:comment>
