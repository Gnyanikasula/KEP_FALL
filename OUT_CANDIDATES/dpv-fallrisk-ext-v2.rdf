    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Use"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/risk/owl#UnauthorisedResourceUse">
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#UnauthorisedActivity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LawfulAIExceptions">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exceptions to transparency obligations for AI systems authorized by law for specific purposes like detecting, preventing, investigating, or prosecuting criminal offences.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 50(1) (chunk EUAI_Art50_Para1)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#RiskLevelMinimal">
    <rdf:type rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#RiskLevelNotHigh"/>
  </rdf:Description>
