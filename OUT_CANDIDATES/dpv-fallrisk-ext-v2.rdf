    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A record of the data subject's consent to the processing of their personal data.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 7(1) (chunk GDPR_Art7_Para1)</rdfs:comment>
