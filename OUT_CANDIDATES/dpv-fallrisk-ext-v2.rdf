    <rdfs:subClassOf rdf:resource="https://w3id.org/kep/fallrisk#ClinicalEvaluation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A report evaluating the results of a post-market clinical follow-up.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU MDR 2017/745 — EU MDR 2017/745, Article 61(11) (chunk EUMDR_Art61_Para11)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#LegitimateInterestPursuit">
