    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 52(6) (chunk EUAI_Art53_Para1_b)</rdfs:comment>
  </rdf:Description>
