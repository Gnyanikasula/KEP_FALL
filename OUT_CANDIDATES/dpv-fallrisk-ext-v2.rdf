    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ability of a high-risk AI system to withstand attempts to alter its use, outputs, or performance by exploiting system vulnerabilities.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 15(5) (chunk EUAI_Art15_Para5)</rdfs:comment>
