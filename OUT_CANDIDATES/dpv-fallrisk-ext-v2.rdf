    <rdf:type rdf:resource="https://w3id.org/dpv/pd/owl#Behavioural"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/pd/owl#CriminalCharge">
    <rdf:type rdf:resource="https://w3id.org/dpv/pd/owl#Criminal"/>
  </rdf:Description>
