    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: GDPR — GDPR, Article 14(2)(b) (chunk GDPR_Art14_Para2_b)</rdfs:comment>
  </rdf:Description>
