    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 15(2) (chunk EUAI_AnnexIV_Point4)</rdfs:comment>
  </rdf:Description>
