    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Authority"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An authority responsible for monitoring the market and enforcing regulations for high-risk AI systems.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 20(2) (chunk EUAI_Art20_Para2)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/kep/fallrisk#DeviceCharacteristicChange">
