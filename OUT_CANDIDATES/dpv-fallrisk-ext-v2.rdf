    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Prohibition"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The act of materially distorting the behaviour of a person or a group of persons.</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Source: EU AI Act — EU AI Act, Article 5(1)(b) (chunk EUAI_Art5_Para1_b)</rdfs:comment>
